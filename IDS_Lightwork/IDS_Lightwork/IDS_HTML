<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IDS Command Center</title>
    <!-- This line imports Tailwind CSS so you don't have to write custom CSS! -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<!-- I gave the body a dark-mode background and white text to start -->
<body class="bg-slate-900 text-slate-100 p-8">

    <!-- ZONE 1: The Header -->
    <div class="max-w-4xl mx-auto mb-8">
        <h1 class="text-3xl font-bold text-red-500">Network IDS Dashboard</h1>
        <p class="text-slate-400">Live Port Scan Detection</p>
    </div>

    <!-- ZONE 2: The Control Panel (Button) -->
    <div class="max-w-4xl mx-auto mb-4">
        <!-- Hint: Add an onclick="" attribute to this button to trigger your JS function -->
        <button class="bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded font-bold">
            Fetch Latest Alerts
        </button>
    </div>

    <!-- ZONE 3: The Data Table -->
    <div class="max-w-4xl mx-auto bg-slate-800 rounded-lg p-4">
        <table class="w-full text-left">
            <thead>
                <tr class="border-b border-slate-700">
                    <th class="p-2">Attacker IP</th>
                    <th class="p-2">Attack Type</th>
                    <th class="p-2">Timestamp</th>
                </tr>
            </thead>
            <!-- Give this tbody an ID so your JavaScript knows exactly where to inject the data! -->
            <tbody id="alert-data-container">
                <!-- JavaScript will inject <tr> elements here later -->
            </tbody>
        </table>
    </div>

    <!-- ZONE 4: The JavaScript Engine -->
    <script>
        // Brainstorming your JS function:
        // 1. Create an async function called fetchAlerts()
        // 2. Use await fetch('http://127.0.0.1:5000/api/alerts')
        // 3. Parse the JSON
        // 4. Use document.getElementById() to grab the tbody
        // 5. Loop through the data and add rows to the tbody
    </script>
</body>
</html>